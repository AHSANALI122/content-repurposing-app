# Postgres connection string (Neon or any Postgres).
# Plain postgresql:// is fine — the app normalizes it to the psycopg driver.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret used to sign JWTs. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me

# How long an access token stays valid (minutes). Default 1440 = 24h.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated allow-list of frontend origins for CORS.
FRONTEND_ORIGINS=http://localhost:3000

# LLM provider — OpenAI SDK pointed at Gemini's OpenAI-compatible endpoint.
# Get a free key at https://aistudio.google.com/apikey
LLM_API_KEY=your-gemini-api-key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash
